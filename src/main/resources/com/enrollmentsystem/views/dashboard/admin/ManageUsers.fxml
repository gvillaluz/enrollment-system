<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane styleClass="anchor-pane" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.enrollmentsystem.controllers.dashboard.admin.UserManagementController">
    <children>
        <VBox prefHeight="529.0" prefWidth="736.0" spacing="10.0" styleClass="main-vbox" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <Label styleClass="title-label" text="Users Management" />
                <HBox alignment="CENTER_RIGHT" maxHeight="258.0" prefHeight="28.0" prefWidth="736.0" styleClass="add-row">
               <children>
                  <Button fx:id="addBtn" graphicTextGap="10.0" maxHeight="29.0" maxWidth="165.0" minHeight="29.0" minWidth="165.0" mnemonicParsing="false" onAction="#openAddModal" prefHeight="29.0" prefWidth="165.0" styleClass="add-user-btn" text="Add New User">
                     <graphic>
                        <ImageView fitHeight="10.0" fitWidth="10.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../../../assets/icons/add-icon.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
               </children>
                </HBox>
                <VBox maxHeight="600.0" prefHeight="200.0" prefWidth="736.0" styleClass="record-container" VBox.vgrow="ALWAYS">
                    <children>
                        <Label styleClass="record-title" text="User Records" />
                        <TableView fx:id="userTable" prefHeight="200.0" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="idCol" editable="false" maxWidth="120.0" minWidth="-Infinity" prefWidth="120.0" sortable="false" text="User ID" />
                                <TableColumn fx:id="lastNameCol" editable="false" maxWidth="165.0" prefWidth="165.0" sortable="false" text="Last Name" />
                        <TableColumn fx:id="firstNameCol" maxWidth="151.0" prefWidth="151.0" text="First Name" />
                        <TableColumn fx:id="middleNameCol" maxWidth="171.0" prefWidth="171.0" text="Middle Name" />
                        <TableColumn fx:id="usernameCol" maxWidth="228.0" prefWidth="228.0" text="Username" />
                                <TableColumn fx:id="roleCol" editable="false" maxWidth="1.7976931348623157E308" minWidth="120.0" prefWidth="120.0" sortable="false" text="Role" />
                        <TableColumn fx:id="statusCol" maxWidth="189.0" prefWidth="189.0" text="Status" />
                                <TableColumn fx:id="actionCol" editable="false" maxWidth="1.7976931348623157E308" prefWidth="250.0" sortable="false" text="Action" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                  <Pagination fx:id="pagination" prefHeight="9.0" prefWidth="696.0" VBox.vgrow="ALWAYS" />
                    </children>
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <VBox.margin>
                        <Insets bottom="50.0" />
                    </VBox.margin>
                </VBox>
            </children>
            <padding>
                <Insets top="10.0" />
            </padding>
        </VBox>
    </children>
</AnchorPane>
