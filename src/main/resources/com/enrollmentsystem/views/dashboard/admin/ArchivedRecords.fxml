<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="568.0" prefWidth="943.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.enrollmentsystem.controllers.dashboard.admin.ArchiveController">
   <children>
      <VBox prefHeight="595.0" prefWidth="1060.0" styleClass="main-vbox" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
         <children>
            <HBox alignment="CENTER">
               <VBox.margin>
                  <Insets bottom="10.0" />
               </VBox.margin>
               <children>
                  <Label styleClass="title-label" text="Archived Records" />
                  <Region prefHeight="0.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
                  <Button fx:id="refreshBtn" mnemonicParsing="false" onAction="#onRefresh" prefHeight="40.0" prefWidth="106.0" styleClass="refresh-btn" text="Refresh" />
               </children>
            </HBox>
            <VBox prefHeight="200.0" prefWidth="100.0" styleClass="sub-vbox" VBox.vgrow="ALWAYS">
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
               <children>
                  <HBox alignment="CENTER_LEFT" prefHeight="32.0" prefWidth="1269.0" styleClass="header">
                     <children>
                        <Label fx:id="subtitle" styleClass="header-title" text="Section Records" />
                        <Region prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
                        <ComboBox fx:id="gradeLevelSelect" maxHeight="27.0" minHeight="27.0" prefHeight="27.0" prefWidth="180.0" promptText="Grade Level" styleClass="dropdown">
                           <HBox.margin>
                              <Insets right="5.0" />
                           </HBox.margin>
                        </ComboBox>
                        <ComboBox fx:id="schoolYearSelect" layoutX="438.0" layoutY="10.0" maxHeight="27.0" minHeight="27.0" prefHeight="27.0" prefWidth="180.0" promptText="School Year" styleClass="dropdown">
                           <HBox.margin>
                              <Insets right="10.0" />
                           </HBox.margin>
                        </ComboBox>
                        <HBox fx:id="searchContainer" alignment="CENTER_RIGHT" prefHeight="53.0" prefWidth="225.0" styleClass="search-container" />
                     </children>
                     <VBox.margin>
                        <Insets bottom="20.0" />
                     </VBox.margin>
                  </HBox>
                  <TableView fx:id="archiveTable" prefWidth="200.0" VBox.vgrow="ALWAYS">
                     <columns>
                        <TableColumn fx:id="lrnCol" maxWidth="200.0" minWidth="100.0" prefWidth="152.0" sortable="false" text="LRN" />
                        <TableColumn fx:id="lastNameCol" maxWidth="200.0" minWidth="100.0" prefWidth="152.0" sortable="false" text="LAST NAME" />
                        <TableColumn fx:id="firstNameCol" maxWidth="200.0" minWidth="100.0" prefWidth="149.0" sortable="false" text="FIRST NAME" />
                        <TableColumn fx:id="middleNameCol" maxWidth="200.0" minWidth="100.0" prefWidth="145.0" sortable="false" text="MIDDLE NAME" />
                        <TableColumn fx:id="ayCol" maxWidth="150.0" minWidth="50.0" prefWidth="94.0" sortable="false" text="A.Y." />
                        <TableColumn fx:id="yearLevelCol" maxWidth="160.0" minWidth="70.0" prefWidth="103.0" sortable="false" text="YEAR LEVEL" />
                        <TableColumn fx:id="termCol" maxWidth="150.0" minWidth="70.0" prefWidth="114.0" sortable="false" text="TERM" />
                        <TableColumn fx:id="trackCol" maxWidth="120.0" minWidth="80.0" prefWidth="125.0" sortable="false" text="TRACK" />
                        <TableColumn fx:id="strandCol" maxWidth="200.0" minWidth="90.0" prefWidth="122.0" sortable="false" text="STRAND" />
                        <TableColumn fx:id="statusCol" maxWidth="-1.0" minWidth="-1.0" prefWidth="-1.0" sortable="false" text="STATUS" />
                        <TableColumn fx:id="actionCol" maxWidth="184.0" minWidth="184.0" prefWidth="184.0" sortable="false" text="ACTION" />
                     </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
                  <Pagination fx:id="pagination" prefHeight="34.0" prefWidth="843.0" VBox.vgrow="ALWAYS" />
               </children>
            </VBox>
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </VBox>
   </children>
</AnchorPane>
