<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane styleClass="anchor-pane" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.enrollmentsystem.controllers.dashboard.academic.StrandManagementController">
    <children>
        <VBox prefHeight="529.0" prefWidth="736.0" spacing="10.0" styleClass="main-vbox" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
            <HBox alignment="CENTER">
               <children>
                      <Label styleClass="title-label" text="Manage SHS Strands" />
                  <Region prefHeight="0.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
                  <Button fx:id="refreshBtn" mnemonicParsing="false" onAction="#onRefresh" prefHeight="40.0" prefWidth="106.0" styleClass="refresh-btn" text="Refresh" />
               </children>
            </HBox>
                <HBox alignment="CENTER_RIGHT" maxHeight="28.0" prefHeight="28.0" prefWidth="738.0" styleClass="add-row">
               <VBox.margin>
                  <Insets />
               </VBox.margin>
               <children>
                  <Button graphicTextGap="10.0" maxHeight="29.0" maxWidth="165.0" minHeight="29.0" minWidth="165.0" mnemonicParsing="false" onAction="#openAddModal" prefHeight="29.0" prefWidth="165.0" styleClass="addTrackBtn" text="Add New Strand">
                     <graphic>
                        <ImageView fitHeight="10.0" fitWidth="10.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../../../assets/icons/add-icon.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
               </children>
                </HBox>
                <VBox maxHeight="600.0" prefHeight="200.0" prefWidth="736.0" styleClass="record-container" VBox.vgrow="ALWAYS">
                    <children>
                        <Label styleClass="record-title" text="SHS Tracks Record" />
                        <TableView fx:id="strandTable" prefHeight="200.0" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="idCol" editable="false" maxWidth="145.0" prefWidth="145.0" sortable="false" text="Strand ID" />
                                <TableColumn fx:id="trackCodeCol" editable="false" maxWidth="206.0" prefWidth="206.0" sortable="false" text="Track Code" />
                                <TableColumn fx:id="strandCodeCol" maxWidth="234.0" prefWidth="234.0" sortable="false" text="Strand Code" />
                                <TableColumn fx:id="descriptionCol" editable="false" maxWidth="1.7976931348623157E308" minWidth="200.0" prefWidth="600.0" sortable="false" text="Description" />
                                <TableColumn fx:id="actionCol" editable="false" maxWidth="149.0" prefWidth="149.0" sortable="false" text="Action" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <VBox.margin>
                        <Insets bottom="50.0" />
                    </VBox.margin>
                </VBox>
            </children>
            <padding>
                <Insets top="10.0" />
            </padding>
        </VBox>
    </children>
</AnchorPane>
