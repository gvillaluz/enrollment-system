<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.enrollmentsystem.controllers.dashboard.academic.ClasslistGeneratorController">
   <children>
      <VBox prefHeight="595.0" prefWidth="1060.0" styleClass="main-vbox" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
         <children>
            <Label styleClass="title-label" text="Classlist Report">
               <VBox.margin>
                  <Insets bottom="10.0" />
               </VBox.margin>
            </Label>
            <VBox prefHeight="200.0" prefWidth="100.0" spacing="10.0" styleClass="sub-vbox" VBox.vgrow="ALWAYS">
               <children>
                  <HBox alignment="CENTER_LEFT" prefHeight="45.0" prefWidth="929.0">
                     <children>
                        <HBox alignment="CENTER_LEFT" prefHeight="45.0" prefWidth="383.0" spacing="5.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label styleClass="labels" text="Grade Level" />
                              <ComboBox fx:id="gradeLevelDropdown" maxHeight="29.0" minWidth="150.0" prefHeight="0.0" promptText="&lt;select one&gt;" styleClass="dropdown" HBox.hgrow="ALWAYS" />
                           </children>
                           <HBox.margin>
                              <Insets right="15.0" />
                           </HBox.margin>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="350.0" spacing="5.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label styleClass="labels" text="Section" />
                              <ComboBox fx:id="sectionDropdown" minWidth="150.0" prefHeight="0.0" promptText="&lt;select one&gt;" styleClass="dropdown" HBox.hgrow="ALWAYS" />
                           </children>
                        </HBox>
                        <Region prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER" prefHeight="45.0" prefWidth="350.0" spacing="10.0">
                           <children>
                              <Button mnemonicParsing="false" onAction="#onClear" styleClass="clear-btn" text="Clear Fields" />
                              <Button layoutX="23.0" layoutY="20.0" mnemonicParsing="false" onAction="#onLoad" styleClass="load-btn" text="Load Data" />
                              <Button mnemonicParsing="false" onAction="#onExport" styleClass="export-btn" text="Export Record" />
                           </children>
                        </HBox>
                     </children>
                  </HBox>
                  <TableView fx:id="classlistTable" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="lrnCol" maxWidth="1.7976931348623157E308" minWidth="100.0" prefWidth="100.0" sortable="false" text="LRN" />
                      <TableColumn fx:id="lastNameCol" maxWidth="1.7976931348623157E308" minWidth="100.0" prefWidth="100.0" sortable="false" text="LAST NAME" />
                        <TableColumn fx:id="firstNameCol" maxWidth="1.7976931348623157E308" minWidth="100.0" prefWidth="100.0" sortable="false" text="FIRST NAME" />
                        <TableColumn fx:id="middleNameCol" maxWidth="1.7976931348623157E308" minWidth="100.0" prefWidth="100.0" sortable="false" text="MIDDLE NAME" />
                        <TableColumn fx:id="gradeLevelCol" maxWidth="1.7976931348623157E308" minWidth="100.0" prefWidth="100.0" sortable="false" text="GRADE LEVEL" />
                        <TableColumn fx:id="sectionCol" maxWidth="1.7976931348623157E308" minWidth="100.0" prefWidth="100.0" sortable="false" text="SECTION" />
                    </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
               </children>
               <padding>
                  <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
               </padding>
            </VBox>
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </VBox>
   </children>
</AnchorPane>
