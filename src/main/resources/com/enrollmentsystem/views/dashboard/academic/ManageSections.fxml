<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane styleClass="anchor-pane" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.enrollmentsystem.controllers.dashboard.academic.SectionManagementController">
    <children>
        <VBox prefHeight="529.0" prefWidth="736.0" spacing="10.0" styleClass="main-vbox" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
            <HBox alignment="CENTER">
               <children>
                      <Label styleClass="title-label" text="Manage SHS Sections" />
                  <Region prefHeight="0.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
                  <Button fx:id="refreshBtn" mnemonicParsing="false" onAction="#onRefresh" prefHeight="40.0" prefWidth="106.0" styleClass="refresh-btn" text="Refresh" />
               </children>
            </HBox>
                <VBox maxHeight="600.0" prefHeight="200.0" prefWidth="736.0" styleClass="record-container" VBox.vgrow="ALWAYS">
                    <children>
                        <Label styleClass="record-title" text="Sections Record" />
                        <TableView fx:id="sectionsTable" prefHeight="200.0" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="idCol" editable="false" maxWidth="127.0" minWidth="70.0" prefWidth="-1.0" sortable="false" text="Section ID" />
                                <TableColumn fx:id="nameCol" editable="false" maxWidth="175.0" minWidth="130.0" prefWidth="-1.0" sortable="false" text="Section Name" />
                                <TableColumn fx:id="syCol" maxWidth="171.0" minWidth="130.0" prefWidth="-1.0" sortable="false" text="School Year" />
                                <TableColumn fx:id="strandCol" maxWidth="236.0" minWidth="160.0" prefWidth="-1.0" sortable="false" text="Strand" />
                                <TableColumn fx:id="roomCol" editable="false" maxWidth="1.7976931348623157E308" minWidth="300.0" prefWidth="-1.0" sortable="false" text="Room Assignment" />
                                <TableColumn fx:id="actionCol" editable="false" maxWidth="189.0" minWidth="150.0" prefWidth="189.0" sortable="false" text="Action" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <VBox.margin>
                        <Insets bottom="50.0" />
                    </VBox.margin>
                </VBox>
            </children>
            <padding>
                <Insets top="10.0" />
            </padding>
        </VBox>
    </children>
</AnchorPane>
