<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox maxHeight="227.0" maxWidth="481.0" minHeight="227.0" minWidth="481.0" prefHeight="227.0" prefWidth="481.0" styleClass="edit-modal" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <Label styleClass="edit-title" text="Edit SHS Track" />
        <HBox alignment="CENTER_LEFT" prefHeight="50.0" prefWidth="451.0" spacing="10.0" VBox.vgrow="ALWAYS">
            <children>
                <Label styleClass="field-labels" text="Track Code:" />
                <TextField styleClass="fields" HBox.hgrow="ALWAYS" />
            </children>
        </HBox>
        <HBox alignment="CENTER_LEFT" prefHeight="52.0" prefWidth="451.0" spacing="10.0" VBox.vgrow="ALWAYS">
            <children>
                <Label styleClass="field-labels" text="Description:" />
                <TextField styleClass="fields" HBox.hgrow="ALWAYS" />
            </children>
        </HBox>
        <HBox alignment="CENTER_RIGHT" prefHeight="45.0" prefWidth="451.0" spacing="10.0">
            <children>
                <Button maxHeight="29.0" maxWidth="95.0" minHeight="29.0" minWidth="95.0" mnemonicParsing="false" prefHeight="29.0" prefWidth="95.0" text="Cancel" />
                <Button maxHeight="29.0" maxWidth="139.0" minHeight="29.0" minWidth="139.0" mnemonicParsing="false" prefHeight="29.0" prefWidth="139.0" text="Save Changes" />
            </children>
        </HBox>
    </children>
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>
</VBox>
