<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane fx:id="mainAnchorPane" styleClass="anchor-pane" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.enrollmentsystem.controllers.dashboard.enrollment.StudentRecordsController">
   <children>
      <VBox prefHeight="610.0" prefWidth="1161.0" styleClass="main-vbox" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
         <children>
            <HBox alignment="CENTER">
               <children>
                  <Label styleClass="title-label" text="Student Records Report" />
                  <Region prefHeight="7.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
                  <Button fx:id="refreshBtn" mnemonicParsing="false" onAction="#onRefresh" prefHeight="40.0" prefWidth="106.0" styleClass="refresh-btn" text="Refresh" />
               </children>
               <VBox.margin>
                  <Insets bottom="10.0" />
               </VBox.margin>
            </HBox>
            <VBox styleClass="sub-vbox" VBox.vgrow="ALWAYS">
               <children>
                  <HBox alignment="CENTER" prefHeight="40.0" prefWidth="776.0">
                     <children>
                        <HBox alignment="CENTER_LEFT" prefHeight="40.0" prefWidth="531.0" spacing="5.0">
                           <children>
                              <Label styleClass="field-labels" text="Search by" />
                              <TextField fx:id="lrnField" maxHeight="27.0" maxWidth="145.0" prefHeight="27.0" prefWidth="145.0" promptText="LRN" styleClass="fields" />
                              <TextField fx:id="lastNameField" maxHeight="27.0" maxWidth="145.0" prefHeight="27.0" prefWidth="145.0" promptText="Last Name" styleClass="fields" />
                              <TextField fx:id="firstNameField" maxHeight="27.0" maxWidth="145.0" prefHeight="27.0" prefWidth="145.0" promptText="First Name" styleClass="fields" />
                           </children>
                        </HBox>
                        <Region prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
                        <Button maxWidth="100.0" mnemonicParsing="false" onAction="#clearFilter" prefWidth="100.0" styleClass="clear-btn" text="Clear">
                           <HBox.margin>
                              <Insets right="5.0" />
                           </HBox.margin></Button>
                        <Button layoutX="1101.0" layoutY="18.0" mnemonicParsing="false" onAction="#loadData" styleClass="load-btn" text="Load Data" />
                     </children>
                  </HBox>
                  <HBox prefHeight="40.0" prefWidth="776.0">
                     <children>
                        <HBox alignment="CENTER_LEFT" prefHeight="40.0" prefWidth="561.0" spacing="5.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label styleClass="field-labels" text="Filter Record(s)" />
                              <ComboBox fx:id="genderDropdown" promptText="&lt;Gender&gt;" styleClass="dropdown" />
                              <ComboBox fx:id="gradeDropdown" promptText="&lt;Grade&gt;" styleClass="dropdown" />
                              <ComboBox fx:id="semesterDropdown" promptText="&lt;Semester&gt;" styleClass="dropdown" />
                              <ComboBox fx:id="trackDropdown" layoutX="545.0" layoutY="17.0" promptText="&lt;Track&gt;" styleClass="dropdown" />
                              <ComboBox fx:id="strandDropdown" layoutX="395.0" layoutY="17.0" promptText="&lt;Strand&gt;" styleClass="dropdown" />
                              <ComboBox fx:id="sectionDropdown" layoutX="529.0" layoutY="18.0" promptText="&lt;Section&gt;" styleClass="dropdown" />
                           </children>
                           <HBox.margin>
                              <Insets />
                           </HBox.margin>
                        </HBox>
                     </children>
                  </HBox>
                  <TableView fx:id="recordsTable" styleClass="table-view" VBox.vgrow="ALWAYS">
                     <columns>
                        <TableColumn fx:id="lrnCol" editable="false" minWidth="50.0" prefWidth="-1.0" sortable="false" styleClass="table-columns" text="LRN" />
                        <TableColumn fx:id="lastnameCol" editable="false" minWidth="50.0" prefWidth="-1.0" sortable="false" styleClass="table-columns" text="LAST NAME" />
                        <TableColumn fx:id="firstnameCol" editable="false" minWidth="50.0" prefWidth="-1.0" sortable="false" styleClass="table-columns" text="FIRST NAME" />
                        <TableColumn fx:id="middlenameCol" editable="false" minWidth="50.0" prefWidth="-1.0" sortable="false" styleClass="table-columns" text="MIDDLE NAME" />
                        <TableColumn fx:id="genderCol" editable="false" minWidth="30.0" prefWidth="-1.0" sortable="false" styleClass="table-columns" text="Gender" />
                        <TableColumn fx:id="gradeCol" editable="false" minWidth="30.0" prefWidth="-1.0" sortable="false" styleClass="table-columns" text="GRADE" />
                        <TableColumn fx:id="termCol" editable="false" minWidth="30.0" prefWidth="-1.0" sortable="false" styleClass="table-columns" text="TERM" />
                        <TableColumn fx:id="trackCol" editable="false" minWidth="30.0" prefWidth="-1.0" sortable="false" styleClass="table-columns" text="TRACK" />
                        <TableColumn fx:id="strandCol" editable="false" minWidth="30.0" prefWidth="-1.0" sortable="false" styleClass="table-columns" text="STRAND" />
                        <TableColumn fx:id="sectionCol" editable="false" minWidth="30.0" prefWidth="-1.0" sortable="false" styleClass="table-columns" text="SECTION" />
                     </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                     <VBox.margin>
                        <Insets top="15.0" />
                     </VBox.margin>
                  </TableView>
                  <Pagination fx:id="pagination" prefHeight="0.0" prefWidth="1161.0" VBox.vgrow="ALWAYS" />
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
